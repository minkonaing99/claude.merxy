{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(python3 *)",
      "Bash(swift build *)",
      "Bash(swift test *)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(mkdir *)",
      "Bash(echo *)",
      "Bash(which *)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(pnpm *)",
      "Bash(tsc *)",
      "mcp__claude-in-chrome__tabs_context_mcp",
      "mcp__claude-in-chrome__get_page_text",
      "mcp__claude-in-chrome__read_page"
    ],
    "deny": [
      "mcp__claude_ai_Gmail",
      "mcp__claude_ai_Google_Calendar",
      "mcp__claude_ai_Google_Drive",
      "mcp__claude_ai_Notion"
    ]
  },
  "model": "opus",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/caveman-activate.js\"",
            "timeout": 5,
            "statusMessage": "Loading caveman mode..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/caveman-mode-tracker.js\"",
            "timeout": 5,
            "statusMessage": "Tracking caveman mode..."
          },
          {
            "type": "command",
            "command": "kill \"$(cat \"$HOME/.claude/.caffeinate.pid\" 2>/dev/null)\" 2>/dev/null; caffeinate -i -t 300 >/dev/null 2>&1 & echo $! > \"$HOME/.claude/.caffeinate.pid\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "kill \"$(cat \"$HOME/.claude/.caffeinate.pid\" 2>/dev/null)\" 2>/dev/null; caffeinate -i -t 300 >/dev/null 2>&1 & echo $! > \"$HOME/.claude/.caffeinate.pid\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "kill \"$(cat \"$HOME/.claude/.caffeinate.pid\" 2>/dev/null)\" 2>/dev/null; rm -f \"$HOME/.claude/.caffeinate.pid\"",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"$HOME/.claude/statusline-command.sh\""
  },
  "enabledPlugins": {
    "caveman@caveman": true,
    "ponytail@ponytail": true,
    "apple-skills@apple-skills": false
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "ponytail": {
      "source": {
        "source": "github",
        "repo": "DietrichGebert/ponytail"
      }
    },
    "apple-skills": {
      "source": {
        "source": "directory",
        "path": "/Users/aurora/.claude/plugins/marketplaces/apple-skills"
      }
    },
    "last30days-skill": {
      "source": {
        "source": "github",
        "repo": "mvanhorn/last30days-skill"
      }
    }
  },
  "effortLevel": "high",
  "tui": "fullscreen"
}
